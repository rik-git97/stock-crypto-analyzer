<!doctype html>
<html><head><meta charset="utf-8">
<title>SCA Live Brief — {{ b.run_date }}</title>
<style>
body{font-family:ui-monospace,Menlo,Consolas,monospace;background:#0b0d10;color:#e6e6e6;max-width:1100px;margin:auto;padding:24px}
h1,h2,h3{color:#ffaa00;border-bottom:1px solid #333;padding-bottom:6px}
table{border-collapse:collapse;width:100%;margin:10px 0;font-size:13px}
td,th{border:1px solid #333;padding:5px 8px;text-align:right}
th{background:#16191d;color:#ffaa00}
td.l{text-align:left}
.ok{color:#7CFC00}.bad{color:#ff6b6b}.muted{color:#888;font-size:0.9em}
pre{background:#16191d;padding:10px;overflow:auto;color:#cdd6f4}
.flag{background:#552;color:#ffd}
.section{margin-bottom:30px}
</style>
</head><body>
<h1>SCA weekly brief — {{ b.run_date }}</h1>
<p class="muted">Generated by SCA paper-trade runner. NOT INVESTMENT ADVICE. Bootstrap CIs on backtest Sharpes still cross zero — treat picks as a tracked hypothesis, not a recommendation.</p>

{% if b.capital_portfolio %}
<div class="section">
<h2>₹{{ "{:,.0f}".format(b.capital_portfolio.capital) }} concentrated portfolio (India equity)</h2>
<p class="muted">Top {{ b.capital_portfolio.target_n_positions }} momentum picks rounded to whole shares. Deployed: ₹{{ "{:,.0f}".format(b.capital_portfolio.capital - b.capital_portfolio.cash_residual) }} ({{ "%.1f"|format(b.capital_portfolio.deployed_pct*100) }}%). Cash residual: ₹{{ "{:,.0f}".format(b.capital_portfolio.cash_residual) }}.</p>
<table>
<tr><th class="l">#</th><th class="l">Ticker</th><th>Price ₹</th><th>Shares</th><th>Allocated ₹</th><th>Weight</th><th>z</th></tr>
{% for pos in b.capital_portfolio.positions %}
<tr>
  <td class="l">{{ loop.index }}</td>
  <td class="l">{{ pos.ticker }}</td>
  <td>{{ "%.2f"|format(pos.last_price) }}</td>
  <td>{{ pos.shares }}</td>
  <td class="ok">{{ "{:,.0f}".format(pos.allocated) }}</td>
  <td>{{ "%.1f"|format(pos.weight*100) }}%</td>
  <td>{{ "%+.2f"|format(pos.z_score) }}</td>
</tr>
{% endfor %}
</table>
{% if b.capital_portfolio.skipped %}
<p class="flag">Skipped (couldn't fit cleanly into capital): {% for s in b.capital_portfolio.skipped[:10] %}{{ s.ticker }} ({{ s.skipped_reason }}){% if not loop.last %}; {% endif %}{% endfor %}{% if b.capital_portfolio.skipped|length > 10 %}; +{{ b.capital_portfolio.skipped|length - 10 }} more{% endif %}</p>
{% endif %}
</div>
{% endif %}

{% if b.options_ideas %}
<div class="section">
<h2>Options ideas — 3-month vertical spreads (defined risk)</h2>
<p class="muted">Regime-gated: bull spread when index ≥ 200-DMA, bear spread when below. All numbers from live NSE option chain.</p>
{% for o in b.options_ideas %}
<h3>{{ o.underlying }} — {{ o.spread_type | replace('_',' ') }} ({{ o.direction }})</h3>
<table>
<tr><th class="l">Field</th><th>Value</th></tr>
<tr><td class="l">Spot</td><td>{{ "%.2f"|format(o.spot) }}</td></tr>
<tr><td class="l">Expiry</td><td>{{ o.expiry }} ({{ o.days_to_expiry }} days)</td></tr>
<tr><td class="l">Long strike / premium</td><td>{{ "%.0f"|format(o.long_strike) }} @ ₹{{ "%.2f"|format(o.long_premium) }}</td></tr>
<tr><td class="l">Short strike / premium</td><td>{{ "%.0f"|format(o.short_strike) }} @ ₹{{ "%.2f"|format(o.short_premium) }}</td></tr>
<tr><td class="l">Lot size</td><td>{{ o.lot_size }}</td></tr>
<tr><td class="l">Net debit (capital required) per lot</td><td>₹{{ "{:,.0f}".format(o.capital_required) }}</td></tr>
<tr><td class="l">Max profit per lot</td><td class="ok">₹{{ "{:,.0f}".format(o.max_profit_per_lot) }}</td></tr>
<tr><td class="l">Max loss per lot</td><td class="bad">₹{{ "{:,.0f}".format(o.max_loss_per_lot) }}</td></tr>
<tr><td class="l">Risk/Reward</td><td>1:{{ "%.2f"|format(o.risk_reward) }}</td></tr>
<tr><td class="l">Breakeven</td><td>{{ "%.0f"|format(o.breakeven) }}</td></tr>
</table>
{% if o.notes %}<p class="flag">Notes: {{ o.notes | join("; ") }}</p>{% endif %}
{% endfor %}
</div>
{% endif %}

{% for s in b.sleeves %}
<div class="section">
<h2>{{ s.sleeve | upper }} — {{ s.config_variant }}</h2>
<p class="muted">As of {{ s.as_of }}. Universe with computable signal: {{ s.universe_size }}. {{ s.longs|length }} longs{% if s.shorts %}, {{ s.shorts|length }} shorts{% endif %}.</p>

{% if s.flagged %}
<p class="flag">⚠ Flagged for data-quality review (excluded from picks): {{ s.flagged | join(", ") }}</p>
{% endif %}

<h3>Long picks (top by combined momentum)</h3>
<table>
<tr><th class="l">#</th><th class="l">Ticker</th><th>Price</th><th>z</th><th>Weight</th><th>1w</th><th>1m</th><th>3m</th><th>6m</th><th>12m</th><th>Vol 30d</th><th>Days listed</th><th class="l">Recent news / flags</th></tr>
{% for p in s.longs %}
<tr>
  <td class="l">{{ loop.index }}</td>
  <td class="l">{{ p.ticker }}</td>
  <td>{{ "%.2f"|format(p.last_price) }}</td>
  <td>{{ "%+.2f"|format(p.z_score) }}</td>
  <td class="ok">{{ "%.2f"|format(p.weight*100) }}%</td>
  <td class="{{ 'ok' if p.ret_1w>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_1w*100) }}%</td>
  <td class="{{ 'ok' if p.ret_1m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_1m*100) }}%</td>
  <td class="{{ 'ok' if p.ret_3m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_3m*100) }}%</td>
  <td class="{{ 'ok' if p.ret_6m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_6m*100) }}%</td>
  <td class="{{ 'ok' if p.ret_12m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_12m*100) }}%</td>
  <td>{{ "%.0f"|format(p.realized_vol_30d*100) }}%</td>
  <td>{{ p.days_listed }}</td>
  <td class="l" style="font-size:11px">
  {% set news = (b.news_per_ticker or {}).get(p.ticker, []) %}
  {% if news %}
    {% for n in news %}
      <div>
        {% if n.flags %}<span class="flag">[{{ n.flags|join(",") }}]</span> {% endif %}
        <a href="{{ n.link }}" target="_blank" style="color:#cdd6f4">{{ n.headline | truncate(80) }}</a>
        <span class="muted">— {{ n.source }}</span>
      </div>
    {% endfor %}
  {% else %}<span class="muted">no recent tagged news</span>{% endif %}
  </td>
</tr>
{% endfor %}
</table>

{% if s.shorts %}
<h3>Short picks</h3>
<table>
<tr><th class="l">#</th><th class="l">Ticker</th><th>Price</th><th>z</th><th>Weight</th><th>1w</th><th>1m</th><th>3m</th><th>6m</th><th>12m</th><th>Vol 30d</th><th>Days listed</th></tr>
{% for p in s.shorts %}
<tr>
  <td class="l">{{ loop.index }}</td>
  <td class="l">{{ p.ticker }}</td>
  <td>{{ "%.2f"|format(p.last_price) }}</td>
  <td>{{ "%+.2f"|format(p.z_score) }}</td>
  <td class="bad">{{ "%.2f"|format(p.weight*100) }}%</td>
  <td class="{{ 'ok' if p.ret_1w>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_1w*100) }}%</td>
  <td class="{{ 'ok' if p.ret_1m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_1m*100) }}%</td>
  <td class="{{ 'ok' if p.ret_3m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_3m*100) }}%</td>
  <td class="{{ 'ok' if p.ret_6m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_6m*100) }}%</td>
  <td class="{{ 'ok' if p.ret_12m>=0 else 'bad' }}">{{ "%+.1f"|format(p.ret_12m*100) }}%</td>
  <td>{{ "%.0f"|format(p.realized_vol_30d*100) }}%</td>
  <td>{{ p.days_listed }}</td>
</tr>
{% endfor %}
</table>
{% endif %}
</div>
{% endfor %}

{% if b.health_summary %}
<h2>Signal health (Information Coefficient)</h2>
<p class="muted">IC = Spearman correlation of last week's z-scores with realized 5-day forward returns. Healthy strategy: IC > 0 most weeks. If 4-week rolling IC stays negative, signal is broken.</p>
<table>
<tr><th class="l">Sleeve</th><th>Weeks tracked</th><th>Latest IC (5d)</th><th>Rolling 4-wk IC</th><th>Status</th></tr>
{% for h in b.health_summary %}
<tr>
  <td class="l">{{ h.sleeve }}</td>
  <td>{{ h.weeks_tracked }}</td>
  <td class="{{ 'ok' if h.latest_ic>=0 else 'bad' }}">{{ "%+.3f"|format(h.latest_ic) }}</td>
  <td class="{{ 'ok' if h.rolling4_ic>=0 else 'bad' }}">{{ "%+.3f"|format(h.rolling4_ic) }}</td>
  <td>{% if h.broken_flag %}<span class="bad">⚠ BROKEN</span>{% else %}<span class="ok">healthy</span>{% endif %}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if b.live_vs_backtest %}
<h2>Paper-trade tracking (live vs. backtest)</h2>
<table>
<tr><th class="l">Sleeve</th><th>Weeks tracked</th><th>Live total</th><th>Live Sharpe</th><th>Backtest Sharpe</th><th>Δ</th></tr>
{% for r in b.live_vs_backtest %}
<tr><td class="l">{{ r.sleeve }}</td><td>{{ r.weeks }}</td><td class="{{ 'ok' if r.live_total>=0 else 'bad' }}">{{ "%+.2f"|format(r.live_total*100) }}%</td><td>{{ "%+.2f"|format(r.live_sharpe) }}</td><td>{{ "%+.2f"|format(r.bt_sharpe) }}</td><td>{{ "%+.2f"|format(r.delta_sharpe) }}</td></tr>
{% endfor %}
</table>
<p class="muted">If live Sharpe diverges from backtest Sharpe by more than 1.0 over 8+ weeks, the strategy is broken — investigate before trading real capital.</p>
{% endif %}

<h2>Notes for this run</h2>
<ul>
{% for note in b.notes %}<li>{{ note }}</li>{% endfor %}
</ul>

<h2>Limitations (still applicable)</h2>
<ul>
{% for l in b.limitations %}<li>{{ l }}</li>{% endfor %}
</ul>
</body></html>
